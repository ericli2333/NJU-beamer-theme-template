% Custom Unofficial Beamer Theme: njutheme (Enhanced Edition)
% Beautified version with modern design elements

\ProvidesPackage{beamerthemenju}[2025/04/24 NJU Custom Theme Enhanced Unofficial]
\RequirePackage{kvoptions}
\RequirePackage{etoolbox}

\SetupKeyvalOptions{
    family=njutheme,
    prefix=njutheme@
}

\DeclareBoolOption[false]{presentation}
\DeclareBoolOption[false]{articlereport}
\ProcessKeyvalOptions*

\ifnjutheme@presentation
    \RequirePackage{ragged2e}
    \RequirePackage{tikz}
    \setbeamerfont{headline institute}{size=\Large}
    \setbeamertemplate{section in toc}[sections numbered]
\else
% ======================
% Font Setup (Times New Roman Look for pdfLaTeX)
% ======================
\RequirePackage[T1]{fontenc}       % Proper font encoding
\RequirePackage{mathptmx}          % Times text + math fonts
\RequirePackage{calc}
\RequirePackage{ragged2e}
\RequirePackage{changepage}
\RequirePackage{pgffor}
\RequirePackage{xcolor}
\RequirePackage{tikz}

\usefonttheme{professionalfonts}

% ======================
% Default Font Settings
% ======================
\setbeamerfont{headline title}{size=\Huge, series=\bfseries}
\setbeamerfont{headline author}{size=\Large}
\setbeamerfont{headline institute}{size=\normalsize}
\setbeamerfont{block title}{size=\large, series=\bfseries}
\setbeamerfont{heading}{series=\bfseries}
\setbeamerfont{footline}{size=\normalsize}
\setbeamerfont{frametitle}{size=\Large, series=\bfseries}
\setbeamerfont{framesubtitle}{size=\normalsize}
\setbeamerfont{author}{size=\small}
\setbeamerfont{institute}{size=\small}
\setbeamerfont{date}{size=\small}
\fi

% ======================
% Logo Management
% ======================
\newcommand{\presentationlogo}[1]{\newcommand{\insertpresentationlogo}{#1}}
\newcommand{\articleinfo}[1]{\newcommand{\insertarticleinfo}{#1}}
\newlength{\logowidth}
\setlength{\logowidth}{10cm}

\newcommand{\logoleft}[1]{\newcommand{\insertlogoleft}{#1}}
\newcommand{\logoright}[1]{\newcommand{\insertlogoright}{#1}}

% ======================
% Title Page (Enhanced)
% ======================
\ifnjutheme@presentation

\ifnjutheme@articlereport
  % Article report mode: show article info instead of title
  \setbeamertemplate{title page}{
    \begin{center}
      \ifdefined\insertarticleinfo
        \usebeamerfont{title}
        \centering
        \begin{center}
          \insertarticleinfo
        \end{center}
      \fi
      
      \vspace{0.15cm}
      {Reporter: \usebeamerfont{author}\insertauthor\par}
      
      \vspace{0.3cm}
      {\usebeamerfont{institute}\insertinstitute\par}
      
      \vspace{0.3cm}
      {\usebeamerfont{date}\insertdate\par}

      \vspace{0.3cm}
      \ifdefined\insertpresentationlogo
        \insertpresentationlogo
      \fi
    \end{center}
  }
\else
  % Normal presentation mode: show title with enhanced styling
  \setbeamertemplate{title page}{
    \begin{center}
      % Top accent bar
      \begin{beamercolorbox}[wd=0.9\paperwidth, ht=0.3ex, dp=0ex]{headline rule}
      \end{beamercolorbox}
      
      \vspace{0.3cm}
      
      % Main title box with purple background
      \begin{beamercolorbox}[wd=0.85\paperwidth, rounded=true, shadow=true, center, sep=8pt]{title box}
      \usebeamerfont{title}
      \centering
      \parbox{0.8\paperwidth}{\centering\inserttitle}
      \end{beamercolorbox}
      
      % Bottom gold accent line
      \begin{beamercolorbox}[wd=0.85\paperwidth, ht=0.15ex, dp=0ex, center]{headline rule}
      \end{beamercolorbox}
      
      \vspace{0.8cm}
      
      % Author with subtle styling
      {\usebeamerfont{author}\color{NJUPurple}\bfseries\insertauthor\par}
      
      \vspace{0.4cm}
      {\usebeamerfont{institute}\color{NJUGray}\insertinstitute\par}
      
      \vspace{0.4cm}
      {\usebeamerfont{date}\color{NJUGray}\insertdate\par}

      \vspace{0.5cm}
      \ifdefined\insertpresentationlogo
        \insertpresentationlogo
      \fi
    \end{center}
  }
\fi

%=========Presentation Header (Enhanced)=======
\setbeamertemplate{headline}{
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=0.5\paperwidth, ht=2.8ex, dp=1.2ex, center]{headline left}%
      \centering
      \vspace{-1ex}
      \usebeamerfont{section in head/foot} \insertsectionhead
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=0.5\paperwidth, ht=2.8ex, dp=1.2ex, center]{headline right}%
      \centering
      \vspace{-0.85ex}
      \usebeamerfont{section in head/foot}
      \ifx\insertframetitle\empty
        % Do nothing
      \else
        \ifnum\value{framenumber}=1
          % Title page: do nothing
        \else
          \ifx\insertframetitle\tableofcontentsname
            % TOC page: do nothing
          \else
            \foreach \n in {\insertsectionstartpage,...,\insertsectionendpage}{
              \ifnum\n=\insertframenumber
                \hyperlink{slide\n}{\raisebox{0.15ex}{\small$\bullet$}}
              \else
                \hyperlink{slide\n}{\color{gray!60}\raisebox{0.15ex}{\small$\bullet$}}
              \fi
              \hspace{0.2em}
            }
          \fi
        \fi
      \fi
    \end{beamercolorbox}%
  }
}

\else
%==========Poster Header=======
\setbeamertemplate{headline}{
  \begin{beamercolorbox}{headline}
    \begin{columns}
      \begin{column}{0.2\paperwidth}
        \ifdefined\insertlogoleft
        \vspace*{0.5ex}
        \hspace{7ex}
        \insertlogoleft
        \fi
      \end{column}
      \begin{column}{0.6\paperwidth}
        \centering
        \vskip2ex
        \ifnjutheme@articlereport
          % Article report mode: show article info instead of title
          \ifdefined\insertarticleinfo
            {\usebeamerfont{headline title} \insertarticleinfo \par}
          \fi
        \else
          % Normal mode: show title
          {\usebeamerfont{headline title} \inserttitle \par}
        \fi
        \vskip1ex
        {\usebeamerfont{headline author} \insertauthor \par}
        \vskip0.5ex
        {\usebeamerfont{headline institute} \insertinstitute \par}
      \end{column}
      \begin{column}{0.2\paperwidth}
        \ifdefined\insertlogoright
        \vspace*{0.5ex}
        \hspace{3.5in}
        \insertlogoright
        \hspace{2ex}
        \fi
      \end{column}
    \end{columns}
    \vspace{1ex}
    \begin{beamercolorbox}[wd=\paperwidth,ht=1ex]{headline rule}
    \end{beamercolorbox}
  \end{beamercolorbox}
}
\fi

%==================== Frame Title (Enhanced) ==========================
\setbeamertemplate{frametitle}{
    \vskip-0.2ex
    \ifnjutheme@presentation
        \begin{beamercolorbox}[wd=\paperwidth, ht=3.2ex, dp=1.2ex, shadow=true]{frametitle}
            \ifx\insertframetitle\empty
            \else
                \hbox to \paperwidth{%
                    \makebox[0.85\paperwidth][l]{%
                        \hspace{1.5ex}\usebeamerfont{frametitle}\insertframetitle%
                    }%
                    \makebox[0.15\paperwidth][r]{%
                        \raisebox{-0.5ex}{\includegraphics[height=2.8ex]{logo/NJU-gold.png}}%
                        \hspace{1ex}%
                    }%
                }
            \fi
        \end{beamercolorbox}
        % Decorative gold underline
        \begin{beamercolorbox}[wd=\paperwidth, ht=0.15ex, dp=0ex]{headline rule}
        \end{beamercolorbox}
    \else
        \begin{beamercolorbox}[wd=\paperwidth, ht=3.2ex, dp=1.2ex, shadow=true]{frametitle}
            \usebeamerfont{frametitle}\hspace{1.5ex}\insertframetitle
        \end{beamercolorbox}
    \fi
    \vskip0.5ex
}

% ======================
% Footer Content (Enhanced)
% ======================
\ifnjutheme@presentation
\setbeamerfont{author in head/foot}{size=\scriptsize}
\setbeamerfont{title in head/foot}{size=\scriptsize}
\setbeamerfont{date in head/foot}{size=\scriptsize}
\setbeamerfont{section in head/foot}{size=\scriptsize}
\setbeamerfont{subsection in head/foot}{size=\scriptsize}

%==========Presentation footer (Enhanced)============
\setbeamertemplate{footline}{
  % Decorative top line of footer
  \begin{beamercolorbox}[wd=\paperwidth, ht=0.1ex, dp=0ex]{headline rule}
  \end{beamercolorbox}
  
  % ===== Bottom: Custom footer =====
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=0.2\paperwidth,ht=2.3ex,dp=1.5ex,center]{footline left}%
        \centering
        \vspace{-0.8 ex}
      \usebeamerfont{section in head/foot} \hspace{1ex}\insertshortauthor
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=0.5\paperwidth,ht=2.3ex,dp=1.5ex,center]{footline center}%
      \centering
      \vspace{-0.8ex}
      \usebeamerfont{section in head/foot}
      \insertshorttitle
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=0.3\paperwidth,ht=2.3ex,dp=1.5ex,right]{footline right}%
      \centering
      \vspace{-1.2 ex}
      \usebeamerfont{section in head/foot}
      \insertshortdate{}\hfill%
      \insertframenumber{} / \inserttotalframenumber\hspace{1ex}
    \end{beamercolorbox}%
  }
}

\else
%=============Poster footer=============
\newcommand{\footercontent}[1]{\newcommand{\insertfootercontent}{#1}}

\setbeamertemplate{footline}{
  \ifdefined\insertfootercontent
  \begin{beamercolorbox}[wd=\paperwidth,ht=3ex,dp=2ex]{footline}
    \usebeamerfont{footline} \insertfootercontent
    \hspace{\sepwidth}
  \end{beamercolorbox}
  \fi
}
\fi

% ================= Box Settings ==============
\RequirePackage{tcolorbox}
\tcbuselibrary{skins, breakable, theorems}

% Define enhanced tcolorbox style keys
\tcbset{
  fancyblockstyle/.style={
    enhanced,
    colframe=NJUPurple,
    coltitle=NJUWhite,
    colbacktitle=NJUPurple,
    colback=NJULightGray,
    title filled=true,
    boxrule=0.8pt,
    toprule=0pt,
    bottomrule=0pt,
    leftrule=3pt,
    rightrule=0pt,
    sharp corners,
    fonttitle=\bfseries\large,
    breakable,
    attach boxed title to top left={xshift=5mm, yshift=-3mm},
    boxed title style={
      sharp corners,
      size=small,
      boxrule=0pt,
      leftrule=0pt,
      rightrule=0pt,
      toprule=0pt,
      bottomrule=0pt
    },
    left=8pt,
    right=8pt,
    top=10pt,
    bottom=8pt,
    shadow={1pt}{-1pt}{0pt}{black!20}
  },
  alertblockstyle/.style={
    enhanced,
    colframe=NJUAlert,
    coltitle=NJUWhite,
    colbacktitle=NJUAlert,
    colback=NJULightGray,
    title filled=true,
    boxrule=0.8pt,
    toprule=0pt,
    bottomrule=0pt,
    leftrule=3pt,
    rightrule=0pt,
    sharp corners,
    fonttitle=\bfseries\large,
    breakable,
    attach boxed title to top left={xshift=5mm, yshift=-3mm},
    boxed title style={
      sharp corners,
      size=small,
      boxrule=0pt,
      leftrule=0pt,
      rightrule=0pt,
      toprule=0pt,
      bottomrule=0pt
    },
    left=8pt,
    right=8pt,
    top=10pt,
    bottom=8pt,
    shadow={1pt}{-1pt}{0pt}{black!20}
  },
  exampleblockstyle/.style={
    enhanced,
    colframe=NJUExample,
    coltitle=NJUWhite,
    colbacktitle=NJUExample,
    colback=NJULightGray,
    title filled=true,
    boxrule=0.8pt,
    toprule=0pt,
    bottomrule=0pt,
    leftrule=3pt,
    rightrule=0pt,
    sharp corners,
    fonttitle=\bfseries\large,
    breakable,
    attach boxed title to top left={xshift=5mm, yshift=-3mm},
    boxed title style={
      sharp corners,
      size=small,
      boxrule=0pt,
      leftrule=0pt,
      rightrule=0pt,
      toprule=0pt,
      bottomrule=0pt
    },
    left=8pt,
    right=8pt,
    top=10pt,
    bottom=8pt,
    shadow={1pt}{-1pt}{0pt}{black!20}
  }
}

\newtcolorbox{alignblock}[1]{
    fancyblockstyle,
    title={#1},
    before upper={\raggedright}
}

\newtcolorbox{fancyblock}[1]{
    fancyblockstyle,
    title={#1}
}

% ======================
% Block Styling (using tcolorbox for both presentation and poster modes)
% ======================
\setbeamertemplate{block begin}{
  \begin{tcolorbox}[fancyblockstyle, title=\insertblocktitle]
  \justifying
}
\setbeamertemplate{block end}{
  \end{tcolorbox}
  \vspace*{1ex}
}

% Alert block
\setbeamertemplate{block alerted begin}{
  \begin{tcolorbox}[alertblockstyle, title=\insertblocktitle]
  \justifying
}
\setbeamertemplate{block alerted end}{
  \end{tcolorbox}
  \vspace*{1ex}
}

% Example block
\setbeamertemplate{block example begin}{
  \begin{tcolorbox}[exampleblockstyle, title=\insertblocktitle]
  \justifying
}
\setbeamertemplate{block example end}{
  \end{tcolorbox}
  \vspace*{1ex}
}

%===================== Table and Images===============
\setbeamertemplate{caption}[numbered]
\setbeamertemplate{caption label separator}{:\hspace{0.3em}}
\setbeamertemplate{caption label format}{\insertcaptionname~\insertcaptionnumber\hspace{0.2em}}

%===================== Itemize/Enumerate Styling ===============
\setbeamertemplate{itemize item}{\color{NJUPurple}\scriptsize$\blacksquare$}
\setbeamertemplate{itemize subitem}{\color{NJUPurpleLight}\scriptsize$\blacktriangleright$}
\setbeamertemplate{itemize subsubitem}{\color{NJUGoldDark}\tiny$\circ$}

\setbeamertemplate{enumerate items}[circle]
\setbeamercolor{enumerate item}{fg=NJUWhite, bg=NJUPurple}
\setbeamercolor{enumerate subitem}{fg=NJUWhite, bg=NJUPurpleLight}
\setbeamercolor{enumerate subsubitem}{fg=NJUWhite, bg=NJUGoldDark}
\setbeamertemplate{enumerate item}{%
  \usebeamercolor[bg]{enumerate item}%
  \begin{tikzpicture}
    \node[circle, fill=NJUPurple, inner sep=1.5pt, text=NJUWhite, font=\bfseries\footnotesize] {\insertenumlabel};
  \end{tikzpicture}%
}
\setbeamertemplate{enumerate subitem}{%
  \usebeamercolor[bg]{enumerate subitem}%
  \begin{tikzpicture}
    \node[circle, fill=NJUPurpleLight, inner sep=1.2pt, text=NJUWhite, font=\bfseries\tiny] {\insertenumlabel.\insertsubenumlabel};
  \end{tikzpicture}%
}

%===================== Section/Subsection Colorbox Styles (Enhanced) ===============
% Enhanced section page with modern design
\newcommand{\sectioncolorbox}[1]{%
  \begin{tcolorbox}[
    enhanced,
    sharp corners,
    colback=NJUPurplePale,
    colframe=NJUPurple,
    boxrule=0pt,
    leftrule=5pt,
    rightrule=0pt,
    toprule=0pt,
    bottomrule=0pt,
    arc=0mm,
    width=\textwidth,
    height=10ex,
    valign=center,
    halign=center,
    fontupper=\huge\bfseries\color{NJUPurple},
    shadow={2pt}{-2pt}{0pt}{black!15}
  ]
  #1
  \end{tcolorbox}%
}

% Enhanced subsection page with modern design
\newcommand{\subsectioncolorbox}[1]{%
  \begin{tcolorbox}[
    enhanced,
    sharp corners,
    colback=NJUGoldLight,
    colframe=NJUGoldDark,
    boxrule=0pt,
    leftrule=5pt,
    rightrule=0pt,
    toprule=0pt,
    bottomrule=0pt,
    arc=0mm,
    width=\textwidth,
    height=8ex,
    valign=center,
    halign=center,
    fontupper=\LARGE\bfseries\color{NJUPurpleDark},
    shadow={2pt}{-2pt}{0pt}{black!15}
  ]
  #1
  \end{tcolorbox}%
}

%===================== Table of Content Settings===============
\AtBeginSection[]{
	\begin{frame}
    \sectioncolorbox{\Roman{section} \quad \insertsection}
    \vspace{1.5ex}
		  \tableofcontents[sectionstyle=show/shaded,subsectionstyle=show/shaded/hide,subsubsectionstyle=show/shaded/hide]
	\end{frame}
}
\AtBeginSubsection[]{
	\begin{frame}
    \subsectioncolorbox{\Roman{section}-\Roman{subsection} \quad \insertsubsection}
    \vspace{1.5ex}
		  \tableofcontents[sectionstyle=show/shaded,subsectionstyle=show/shaded/hide,subsubsectionstyle=show/shaded/hide]
	\end{frame}
}

\makeatletter
\patchcmd{\beamer@@frametitle}
    {\gdef\insertframetitle}
    {\hypertarget{slide\theframenumber}{}\gdef\insertframetitle}
    {}{}
\makeatother
