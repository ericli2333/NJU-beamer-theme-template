% beamercolorthemenjucolor.sty
% Enhanced NJU Color Theme - Modern Elegant Palette
% Based on NJU Beamer Theme by Eric Li, beautified version

\ProvidesPackage{beamercolorthemenjucolor}[2025/04/24 NJU Color Theme Enhanced Unofficial]

\RequirePackage{kvoptions}

\SetupKeyvalOptions{
    family=njucolortheme,
    prefix=njucolor@
}

\DeclareBoolOption[false]{presentation}
\ProcessKeyvalOptions*

% ========== Core NJU Color Palette ==========
\definecolor{NJUPurple}{RGB}{108, 15, 111}       % Primary: Deep NJU Purple
\definecolor{NJUPurpleDark}{RGB}{80, 10, 82}     % Darker purple for depth
\definecolor{NJUPurpleLight}{RGB}{160, 80, 162}  % Lighter purple for accents
\definecolor{NJUPurplePale}{RGB}{245, 235, 245}  % Very light purple for backgrounds

\definecolor{NJUGold}{RGB}{206, 184, 136}        % Primary gold
\definecolor{NJUGoldDark}{RGB}{176, 150, 96}     % Darker gold
\definecolor{NJUGoldLight}{RGB}{235, 225, 200}   % Light gold background

\definecolor{NJUWhite}{RGB}{255, 255, 255}
\definecolor{NJUBlack}{RGB}{30, 30, 30}          % Soft black
\definecolor{NJUGray}{RGB}{120, 120, 120}        % Medium gray
\definecolor{NJULightGray}{RGB}{248, 248, 248}   % Near-white gray
\definecolor{NJUBorderGray}{RGB}{220, 220, 220}  % Border gray

% ========== Semantic Accent Colors ==========
\definecolor{NJUAlert}{RGB}{180, 50, 50}         % Refined alert red
\definecolor{NJUExample}{RGB}{50, 120, 80}        % Refined example green
\definecolor{NJUInfo}{RGB}{60, 100, 160}          % Info blue

% ========== Background & Base Text ==========
\setbeamercolor{background canvas}{bg=NJUWhite}
\setbeamercolor{normal text}{fg=NJUBlack}
\setbeamercolor{alerted text}{fg=NJUAlert}

% ========== Frame Title ==========
\setbeamercolor{frametitle}{fg=NJUWhite, bg=NJUPurple}
\setbeamercolor{framesubtitle}{fg=NJUGoldLight, bg=NJUPurple}

% ========== Title & Header ==========
\ifnjucolor@presentation
  \setbeamercolor{title}{fg=NJUWhite, bg=NJUPurple}
  \setbeamercolor{title box}{fg=NJUWhite, bg=NJUPurple}
  \setbeamercolor{headline left}{fg=NJUGold, bg=NJUPurple}
  \setbeamercolor{headline right}{fg=NJUGold, bg=NJUPurpleDark}
\else
  \setbeamercolor{headline}{bg=NJUPurple, fg=NJUWhite}
  \setbeamercolor{headline rule}{bg=NJUGold}
  \setbeamercolor{title}{fg=NJUWhite, bg=NJUPurple}
  \setbeamercolor{headline title}{fg=NJUWhite}
  \setbeamercolor{headline author}{fg=NJUGoldLight}
  \setbeamercolor{headline institute}{fg=NJUGoldLight}
\fi

% ========== Footer ==========
\ifnjucolor@presentation
  \setbeamercolor{footline left}{fg=NJUGold, bg=NJUPurpleDark}
  \setbeamercolor{footline center}{fg=NJUPurple, bg=NJUGoldLight}
  \setbeamercolor{footline right}{fg=NJUGold, bg=NJUPurpleDark}
  \setbeamercolor{footline}{fg=NJUGold, bg=NJUPurpleDark}
\else
  \setbeamercolor{footline}{fg=NJUWhite, bg=NJUPurple}
\fi

% ========== Blocks ==========
\ifnjucolor@presentation
  \setbeamercolor{block title}{fg=NJUWhite, bg=NJUPurple}
  \setbeamercolor{block body}{fg=NJUBlack, bg=NJULightGray}
  \setbeamercolor{block alerted title}{fg=NJUWhite, bg=NJUAlert}
  \setbeamercolor{block alerted body}{fg=NJUBlack, bg=NJULightGray}
  \setbeamercolor{block example title}{fg=NJUWhite, bg=NJUExample}
  \setbeamercolor{block example body}{fg=NJUBlack, bg=NJULightGray}
\else
  \setbeamercolor{block title}{fg=NJUPurple, bg=NJUGoldLight}
  \setbeamercolor{block body}{fg=NJUBlack, bg=NJULightGray}
  \setbeamercolor{block alerted title}{fg=NJUWhite, bg=NJUAlert}
  \setbeamercolor{block alerted body}{fg=NJUBlack, bg=NJULightGray}
  \setbeamercolor{block example title}{fg=NJUWhite, bg=NJUExample}
  \setbeamercolor{block example body}{fg=NJUBlack, bg=NJULightGray}
\fi

% ========== Lists ==========
\setbeamercolor{item projected}{fg=NJUWhite, bg=NJUPurple}
\setbeamercolor{itemize item}{fg=NJUPurple}
\setbeamercolor{itemize subitem}{fg=NJUPurpleLight}
\setbeamercolor{itemize subsubitem}{fg=NJUGoldDark}
\setbeamercolor{enumerate item}{fg=NJUPurple}
\setbeamercolor{enumerate subitem}{fg=NJUPurpleLight}
\setbeamercolor{enumerate subsubitem}{fg=NJUGoldDark}

% ========== Navigation (Hidden) ==========
\setbeamercolor{navigation symbols}{fg=NJUPurple}
\beamertemplatenavigationsymbolsempty

% ========== Captions and Table of Contents ==========
\setbeamercolor{caption name}{fg=NJUPurple}
\setbeamercolor{caption}{fg=NJUBlack}
\setbeamercolor{section in toc}{fg=NJUPurple, bg=NJULightGray}
\setbeamercolor{subsection in toc}{fg=NJUBlack, bg=NJULightGray}
\setbeamercolor{section in head/foot}{fg=NJUGold}
\setbeamercolor{subsection in head/foot}{fg=NJUGoldLight}

% ========== Structure Elements ==========
\setbeamercolor{structure}{fg=NJUPurple}
\setbeamercolor{description item}{fg=NJUPurple}
\setbeamercolor{date}{fg=NJUGray}
\setbeamercolor{author}{fg=NJUBlack}
\setbeamercolor{institute}{fg=NJUGray}
